{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "preferredVersions": {
    "php": "8.0",
    "wp": "latest"
  },
  "landingPage": "/?p=1",
  "steps": [
    {
      "step": "login",
      "username": "admin",
      "password": "password"
    },
    {
      "step": "installPlugin",
      "pluginZipFile": {
        "resource": "wordpress.org/plugins",
        "slug": "big-emoji-comments"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "runPHP",
      "code": "<?php wp_insert_comment( [ 'comment_post_ID' => 1, 'comment_author' => 'Emoji Fan', 'comment_author_email' => 'fan@example.com', 'comment_content' => '😀 😃 😄', 'comment_type' => 'comment', 'comment_approved' => 1 ] );"
    }
  ]
}
