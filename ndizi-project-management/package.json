{
	"name": "ndizi-project-management",
	"version": "1.2.0",
	"description": "Ndizi Project Management builds a complete project management system in WordPress.",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"files": [
		"Ndizi.php",
		"uninstall.php",
		"readme.txt",
		"LICENSE",
		"build",
		"includes",
		"templates",
		"languages",
		"playground",
		"src"
	],
	"scripts": {
		"start": "wp-scripts start",
		"build": "wp-scripts build",
		"build:vendor": "wp-scripts build --config webpack.vendor.js",
		"build:all": "npm run build:vendor && npm run build",
		"plugin-zip": "wp-scripts plugin-zip",
		"lint:js": "wp-scripts lint-js",
		"lint:style": "wp-scripts lint-style",
		"lint:md": "wp-scripts lint-md-docs README.md",
		"format": "wp-scripts format",
		"lint": "npm run lint:js && npm run lint:style && npm run lint:md"
	},
	"devDependencies": {
		"@wordpress/dataviews": "^16.0.0",
		"@wordpress/scripts": "^27.0.0"
