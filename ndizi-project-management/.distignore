# Files and directories that should never ship in the WordPress.org package.
# Honored by the 10up WordPress.org deploy action; for the manual rsync→SVN
# flow add matching --exclude entries.

# Build sources (only the compiled /build is shipped)
/src
/node_modules
webpack.config.js
webpack.shared.js
webpack.vendor.js
package.json
package-lock.json
.eslintignore

# PHP dev tooling
/vendor
composer.json
composer.lock
phpcs.xml

# Repo meta
/.wordpress-org
.gitignore
.distignore
AGENTS.md
API-AUTHENTICATION.md
TODO.md
README.md
REVIEW.md
/chrome-extension

# Keep the languages/ dir and .pot, but drop the placeholder
languages/.gitkeep
