# Files and directories that should never ship in the WordPress.org package.
# Honored by the 10up WordPress.org deploy action; for the manual rsync→SVN
# flow add matching --exclude entries.

# Build sources
# NOTE: /src is intentionally shipped alongside /build so the human-readable
# source for every compiled JS/CSS asset is available in the package, per the
# WordPress.org guideline that compressed code must have a public source.
/node_modules
webpack.config.js
webpack.shared.js
webpack.vendor.js
package.json
package-lock.json
.eslintignore

# PHP dev tooling
/vendor
composer.json
composer.lock
phpcs.xml

# Repo meta
/.wordpress-org
.gitignore
.distignore
AGENTS.md
API-AUTHENTICATION.md
TODO.md
README.md
REVIEW.md
DOTORG_REVIEW.md
/chrome-extension

# Keep the languages/ dir and .pot, but drop the placeholder
languages/.gitkeep
